# Copy this file to .env for a production-like Docker Compose run.
# Use different values from local development before deploying anywhere public.

DATABASE_NAME=studyvault_iws
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=replace_with_a_strong_database_password
PROD_DATABASE_HOST_PORT=15433

PROD_FRONTEND_HOST_PORT=8080
PROD_CORS_ORIGIN=http://localhost:8080
PROD_FRONTEND_URL=http://localhost:8080
PROD_VITE_API_BASE_URL=/api

JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
AUTH_RETURN_RESET_TOKEN=false
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace_with_a_strong_admin_password
SWAGGER_ENABLED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="StudyVault <no-reply@studyvault.local>"

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL_FALLBACK=gemini-2.0-flash
GEMINI_TEXT_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
