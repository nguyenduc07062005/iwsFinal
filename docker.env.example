# Optional Docker Compose overrides.
# Copy this file to .env if you need real secrets or non-default ports.

DATABASE_NAME=studyvault_iws
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST_PORT=15432

JWT_SECRET=change_me_for_local_docker
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
AUTH_RETURN_RESET_TOKEN=true
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=
SWAGGER_ENABLED=true

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000/api

# Email is optional unless you want real verification/reset links.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="StudyVault <no-reply@studyvault.local>"

# AI features need a real key.
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TEXT_MODEL_FALLBACK=gemini-2.5-flash-lite
GEMINI_TEXT_MODEL_FALLBACKS=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
