# Application
PORT=8000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=studyvault_iws
DATABASE_SYNC=false
DATABASE_LOGGING=false

# JWT
JWT_SECRET=change_me_before_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_MINUTES=1440
RESET_PASSWORD_TTL_MINUTES=30
AUTH_RETURN_RESET_TOKEN=false
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=
SWAGGER_ENABLED=true

# Gmail SMTP for real password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM="StudyVault <your_gmail_address@gmail.com>"

# AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TEXT_MODEL_FALLBACK=gemini-2.5-flash-lite
GEMINI_TEXT_MODEL_FALLBACKS=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
