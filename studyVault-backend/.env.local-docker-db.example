# Backend local development while PostgreSQL runs from docker compose.
# Usage:
#   1. From project root: docker compose up -d database
#   2. Copy this file to studyVault-backend/.env
#   3. From studyVault-backend: npm run migration:run && npm run start:dev

# Application
PORT=8000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:3000

# Database exposed by docker-compose.yml
DATABASE_HOST=localhost
DATABASE_PORT=15432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=studyvault_iws
DATABASE_SYNC=false
DATABASE_LOGGING=false

# Auth/session
JWT_SECRET=change_me_for_local_dev
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_MINUTES=1440
RESET_PASSWORD_TTL_MINUTES=30
AUTH_RETURN_RESET_TOKEN=true
ADMIN_EMAILS=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=
SWAGGER_ENABLED=true

# Gmail SMTP for real verification/reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="StudyVault <no-reply@studyvault.local>"

# AI
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL_FALLBACK=gemini-2.0-flash
GEMINI_TEXT_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
